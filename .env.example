# Project Solace environment example.
# Copy this file to .env on your server and change the values.

FLASK_SECRET_KEY=change-this-to-a-long-random-string
SOLACE_ADMIN_USERNAME=admin
SOLACE_ADMIN_PASSWORD=change-this-password
DATABASE_URL=sqlite:////app/instance/solace.db
TZ=Australia/Brisbane

# Host port used by docker-compose.yml.
# Change this if 5055 is already in use.
SOLACE_PORT=5055

# Set to true only for local development debugging. Leave false on servers.
FLASK_DEBUG=false
